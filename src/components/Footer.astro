---
const year = new Date().getFullYear();
---

<footer class="bg-primary-dark text-gray-300">
  <!-- ASCII divider -->
  <div class="border-t border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-1">
      <div class="ascii-pattern text-white/[0.05] text-[8px] text-center tracking-[0.3em] select-none overflow-hidden whitespace-nowrap" aria-hidden="true">
        ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─ ─
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-8 lg:gap-12">
      <div class="lg:col-span-4">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-accent rounded-lg flex items-center justify-center font-bold text-primary-dark text-xl">
            N
          </div>
          <div>
            <span class="text-xl font-bold text-white tracking-tight">Navvy</span>
            <span class="block text-[11px] text-gray-500 -mt-0.5 uppercase tracking-wide">s.r.o.</span>
          </div>
        </div>
        <p class="text-sm leading-relaxed mb-4">
          Prodej obalů a obalového materiálu.<br />
          Velkoobchod s kompletní nabídkou polyethylenových obalů pro firmy a podnikatele.
        </p>
        <p class="text-xs text-gray-500">
          IČO: 26210347
        </p>
      </div>

      <div class="lg:col-span-3">
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Sortiment</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/sortiment#ldpe-pytle" class="hover:text-white transition-colors">LDPE pytle a sáčky</a></li>
          <li><a href="/sortiment#ldpe-folie" class="hover:text-white transition-colors">LDPE fólie</a></li>
          <li><a href="/sortiment#stretch-folie" class="hover:text-white transition-colors">Stretch fólie</a></li>
          <li><a href="/sortiment#hdpe-folie" class="hover:text-white transition-colors">HDPE fólie a pytle</a></li>
          <li><a href="/sortiment#paletizacni-pytle" class="hover:text-white transition-colors">Paletizační pytle</a></li>
          <li><a href="/sortiment#plachty" class="hover:text-white transition-colors">Plachty</a></li>
          <li><a href="/sortiment#pasky" class="hover:text-white transition-colors">Pásky</a></li>
          <li><a href="/sortiment#folie" class="hover:text-white transition-colors">Bublinkové a pěnové fólie</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Společnost</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">O nás</a></li>
          <li><a href="/sortiment" class="hover:text-white transition-colors">Sortiment</a></li>
          <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
          <li><a href="mailto:navvy.hrdlicka@gmail.com" class="hover:text-white transition-colors">Poptávka</a></li>
        </ul>
      </div>

      <div class="lg:col-span-3">
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Kontakt</h3>
        <ul class="space-y-3.5 text-sm">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span>Stroupežnického 298/16<br />284 01 Kutná Hora</span>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <a href="tel:+420606466477" class="hover:text-white transition-colors">+420 606 466 477</a>
          </li>
          <li class="flex items-center gap-2.5">
            <svg class="w-4 h-4 shrink-0 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <a href="mailto:navvy.hrdlicka@gmail.com" class="hover:text-white transition-colors">navvy.hrdlicka@gmail.com</a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-gray-500">
      <p>&copy; {year} Navvy s.r.o. &mdash; Všechna práva vyhrazena.</p>
      <p class="font-mono text-gray-600">IČO 26210347</p>
    </div>
  </div>
</footer>
