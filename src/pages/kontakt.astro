---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Kontakt – Navvy s.r.o." description="Kontaktujte Navvy s.r.o. – Stroupežnického 298/16, 284 01 Kutná Hora. Tel: +420 606 466 477, E-mail: navvy.hrdlicka@gmail.com">
  <Header />

  <!-- Page Header -->
  <section class="relative bg-primary-dark text-white py-16 sm:py-24 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-1.jpg" alt="" class="w-full h-full object-cover opacity-15" />
      <div class="absolute inset-0 bg-gradient-to-b from-primary-dark/90 to-primary-dark"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/20 text-accent text-xs font-semibold uppercase tracking-wider mb-4">
          Navvy s.r.o.
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-5">Kontakt</h1>
        <p class="text-lg text-gray-300 leading-relaxed max-w-2xl">
          Kontaktujte nás s vaší poptávkou nebo dotazem. Rádi vám připravíme nabídku na míru s dopravou zdarma po celé ČR.
        </p>
      </div>

    </div>
  </section>

  <!-- Quick contact bar -->
  <div class="bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-6 sm:gap-10 py-5">
        <a href="tel:+420606466477" class="flex items-center gap-2.5 text-gray-700 hover:text-primary transition-colors group">
          <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center group-hover:bg-primary/15 transition-colors">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <span class="font-semibold text-sm">+420 606 466 477</span>
        </a>
        <a href="mailto:navvy.hrdlicka@gmail.com" class="flex items-center gap-2.5 text-gray-700 hover:text-primary transition-colors group">
          <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center group-hover:bg-primary/15 transition-colors">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <span class="font-semibold text-sm">navvy.hrdlicka@gmail.com</span>
        </a>
        <div class="flex items-center gap-2.5 text-gray-700">
          <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center">
            <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <span class="font-semibold text-sm">Kutná Hora</span>
        </div>
      </div>
    </div>
  </div>

  <section class="py-16 sm:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">

        <!-- Contact Info -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-7 sm:p-8">
          <h2 class="text-xl font-bold text-gray-900 mb-6">Kontaktní údaje</h2>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 mb-0.5">Adresa</p>
                <p class="text-gray-600 text-sm">Stroupežnického 298/16<br />284 01 Kutná Hora</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 mb-0.5">Telefon</p>
                <a href="tel:+420606466477" class="text-primary hover:text-primary-light text-sm block">+420 606 466 477</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-gray-900 mb-0.5">E-mail</p>
                <a href="mailto:navvy.hrdlicka@gmail.com" class="text-primary hover:text-primary-light text-sm block">navvy.hrdlicka@gmail.com</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Billing Info -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-7 sm:p-8">
          <h2 class="text-xl font-bold text-gray-900 mb-4">Fakturační údaje</h2>
          <div class="text-sm text-gray-600 space-y-1.5">
            <p><span class="font-semibold text-gray-900">Navvy s.r.o.</span></p>
            <p>Stroupežnického 298/16</p>
            <p>284 01 Kutná Hora</p>
            <div class="pt-3 mt-3 border-t border-gray-100 space-y-1">
              <p class="font-mono text-xs"><span class="text-gray-400">IČO:</span> <span class="text-gray-700">26210347</span></p>
            </div>
          </div>
        </div>

        <!-- ASCII business card -->
        <div class="bg-primary-dark rounded-2xl p-6 hidden lg:flex items-center justify-center">
          <div class="ascii-pattern text-accent/70 text-[11px] leading-[1.4] whitespace-pre">{`╔════════════════════════════════════╗
║                                    ║
║  ██  ██  NAVVY s.r.o.              ║
║  ███ ██                            ║
║  ██ ███  Obalovy material          ║
║  ██  ██  Kutna Hora                ║
║                                    ║
║  tel:  +420 606 466 477            ║
║  mail: navvy.hrdlicka@gmail.com    ║
║  web:  www.navvy.cz                ║
║                                    ║
╚════════════════════════════════════╝`}</div>
        </div>
      </div>

      <!-- Map -->
      <div class="mt-12 bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="p-6 sm:p-8 border-b border-gray-100 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
          <div>
            <h2 class="text-xl font-bold text-gray-900">Kde nás najdete</h2>
            <p class="text-gray-500 text-sm mt-1">Stroupežnického 298/16, Hlouška, 284 01 Kutná Hora</p>
          </div>
          <a
            href="https://www.google.com/maps/place/Stroupežnického+298/16,+Hlouška,+284+01+Kutná+Hora"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-primary hover:text-primary-light font-semibold transition-colors"
          >
            Otevřít v mapách
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2566.9148308983026!2d15.275641115211638!3d49.95670013069978!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x470c41004fcf6a21%3A0x70f98c04c4283f13!2zU3Ryb3VwZcW-bmlja8OpaG8gMjk4LzE2LCBIbG91xaFrYSwgMjg0IDAxIEt1dG7DoSBIb3Jh!5e0!3m2!1scs!2scz!4v1515416406078"
          class="w-full h-80 sm:h-96"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
